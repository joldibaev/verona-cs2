# Optional. Leave empty for LAN-only development.
GSLT=

SERVER_HOSTNAME=Verona development server
SERVER_PASSWORD=
RCON_PASSWORD=change-me
START_MAP=de_dust2
# 0/0 is Casual. These are passed directly to CS2.
GAME_TYPE=0
GAME_MODE=0
MAX_PLAYERS=10

# Set to 1 to validate all CS2 files on every container start (slow).
STEAMCMD_VALIDATE=0

# Admin panel: http://localhost:8080
# One-time bootstrap only when the database contains no admin role yet.
ADMIN_STEAM_IDS=
# Optional official FACEIT Data API key for FACEIT ELO enrichment.
FACEIT_API_KEY=
VERONA_PLUGIN_API_KEY=replace-with-a-long-random-value
POSTGRES_PASSWORD=change-me
