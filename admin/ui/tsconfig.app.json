{
  "compilerOptions": {
    "target": "ES2022", "useDefineForClassFields": true, "module": "ESNext",
    "moduleResolution": "Bundler", "strict": true, "jsx": "react-jsx",
    "resolveJsonModule": true, "isolatedModules": true, "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"], "types": ["vite/client"], "noEmit": true,
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
